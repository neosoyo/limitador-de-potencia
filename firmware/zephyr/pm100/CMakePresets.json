{
    "version": 2,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "build",
            "displayName": "Build for xiao_ble",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "BOARD": "xiao_ble/nrf52840",
                "DTC_OVERLAY_FILE": "xiao_ble_nrf52840.overlay",
                "DEBUG_THREAD_INFO": false
            }
        }
    ]
}